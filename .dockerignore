# Git関連のファイルは不要
/.git/
/.gitignore

# Bundlerのローカル設定をコピーしない（環境依存があるため）
/.bundle

# 環境変数ファイルは秘匿情報なのでコピーしない
/.env*

# Railsの認証鍵をコピーしない（セキュリティリスク）
/config/master.key
/config/credentials/*.key

# ログ・一時ファイルはビルドに不要
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# プロセスIDファイルは不要だけど、ディレクトリ自体は残す
/tmp/pids/*
!/tmp/pids/.keep

# ActiveStorageのファイル保存やSQLite DBはコピーしない
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# ビルド済みのアセット類はコピー不要
/node_modules/
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets

# GitHub ActionsなどCI設定ファイルは不要
/.github

# デプロイツールKamalの設定ファイルは不要
/config/deploy*.yml
/.kamal

# 開発専用のDev Container設定は不要
/.devcontainer

# Dockerfileやcomposeファイル自体はコピーしない
/.dockerignore
/Dockerfile*

*.DS_Store
