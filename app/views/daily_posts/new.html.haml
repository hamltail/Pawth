%div.flex.items-center.justify-center.min-h-screen.bg-gray-50
  %div.bg-white.shadow-md.rounded-lg.px-8.py-8.max-w-md.w-full
    %h1.text-2xl.font-bold.mb-4.text-center DailyPosts#new
    %h2.text-xl.font-semibold.mb-6.text-center 今日何をした？

    .mb-4
      = link_to "← 戻る", (request.referer || profile_path(username: current_user.username)),
          class: "text-blue-500 hover:underline text-sm"

    = form_with model: @daily_post, url: daily_posts_path, class: "space-y-6" do |f| 
      %div
        = f.text_area :content,
            rows: 6,
            placeholder: "今日何をした？",
            class: "border border-gray-300 rounded w-full p-3 text-base focus:ring-2 focus:ring-blue-200 focus:border-blue-400 resize-none"
      %div.flex.justify-end
        = f.submit "投稿",
            class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-6 rounded shadow"
