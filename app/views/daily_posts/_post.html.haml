%li.group.relative.mb-4.rounded-2xl.bg-white.p-5.shadow-sm.ring-1.ring-gray-300.transition.transform.hover:-translate-y-0.5.hover:shadow-lg{
  id: "post_#{post.id}"
}
  .flex.items-center.justify-between.gap-3
    .inline-flex.items-center.gap-1.px-2.5.py-1.rounded-full.font-semibold.text-gray-700.bg-gray-100.ring-1.ring-gray-200{
      class: 'text-[12px] shadow-[inset_0_-1px_0_rgba(255,255,255,.6)]'
    }
      = l(post.posted_on, format: :default)
    - if post.posted_on == Date.current
      - if post.edit_count < DailyPost::EDIT_COUNT_LIMIT
        = link_to t('daily_posts.shared.edit'),
          edit_daily_post_path(post),
          data: { turbo_frame: 'modal' },
          class: 'text-brand hover:underline font-semibold text-sm'
      - else
        %button.text-gray-500.font-semibold.text-sm.cursor-not-allowed{
          type: 'button',
          onclick: "alert('#{t('daily_posts.shared.edit_limit_alert', limit: DailyPost::EDIT_COUNT_LIMIT)}')"
        }= t('daily_posts.shared.edit')
      %button.text-gray-500.font-semibold.text-sm.ml-3.cursor-not-allowed{
        type: 'button',
        onclick: "alert('#{t('daily_posts.shared.delete_today_alert')}')"
      }= t('daily_posts.shared.delete')
    - else
      = link_to t('daily_posts.shared.delete'),
        daily_post_path(post),
        class: 'text-red-600 hover:underline font-semibold text-sm',
        data: { controller: 'confirm',
          action: 'click->confirm#click',
          confirm_message_value: t('daily_posts.shared.delete_confirm'),
          confirm_method_value: 'delete' }
  .mt-3.leading-relaxed.text-gray-800.whitespace-pre-wrap.break-words= h(post.content)
