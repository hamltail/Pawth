%div.bg-white.shadow-md.rounded-lg.px-8.py-8.relative
  %h1.text-2xl.font-bold.mb-6.text-center= "#{current_user.username}'s Posts"
  %div.absolute.top-8.right-8
    = link_to "＋", new_daily_post_path, data: { turbo_frame: "modal" },
        class: "inline-block bg-teal-400 hover:bg-teal-500 text-white font-bold py-2 px-4 rounded-full text-xl"
  = turbo_frame_tag "modal"
  = form_with url: daily_posts_path, method: :get, local: true, class: "mb-4 flex justify-center space-x-2" do |f|
    = f.text_field :q, placeholder: "キーワード検索", value: params[:q], class: "px-4 py-2 border border-gray-300 rounded-md w-64"
    = f.select :year, options_for_select((2024..Date.today.year).to_a.reverse, params[:year]), { prompt: "年" }, class: "px-2 py-2 border border-gray-300 rounded-md"
    = f.select :month, options_for_select((1..12).to_a.map { |m| [m, m] }, params[:month]), { prompt: "月" }, class: "px-2 py-2 border border-gray-300 rounded-md"
    = f.submit "検索", class: "px-4 py-2 bg-teal-400 text-white rounded-md hover:bg-teal-500"
  %ul#posts.space-y-6.mt-8
    - @daily_posts.each do |post|
      = render "post", post: post
  %div{ class: "mt-6 flex flex-col items-center gap-2" }
    %div{ class: "flex gap-2 [&_a]:px-3 [&_a]:py-1 [&_a]:rounded-full [&_a]:ring-1 [&_a]:ring-gray-300 [&_a]:text-gray-700 [&_a]:transition [&_a:hover]:bg-gray-100 [&_span]:px-3 [&_span]:py-1 [&_span]:rounded-full [&_span]:ring-1 [&_span]:ring-teal-400 [&_span]:bg-teal-400 [&_span]:text-white" }
      = pagy_nav(@pagy).html_safe
    %div.text-xs.text-gray-500
      = "Page #{@pagy.page} / #{@pagy.pages}"
