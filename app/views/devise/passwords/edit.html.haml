%div.flex.items-center.justify-center.min-h-screen.bg-gray-50
  %div.bg-white.shadow-md.rounded-lg.px-8.py-8.max-w-sm.w-full
    %h2.text-2xl.font-bold.mb-6.text-center
      = t("devise.passwords.edit.change_your_password")
    - if resource.errors.any?
      %div.bg-red-100.border.border-red-400.text-red-700.px-4.py-4.rounded.mb-6
        %p.font-bold= "#{resource.errors.count}件のエラーがあります。"
        %ul.ml-4.list-disc
          - priority = [:password, :password_confirmation]
          - sorted_errors = resource.errors.messages.sort_by { |k, _| priority.index(k) || 999 }
          - sorted_errors.each do |attribute, messages|
            - messages.each do |msg|
              %li= resource.class.human_attribute_name(attribute) + msg
    = form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f|
      = f.hidden_field :reset_password_token
      .mb-4
        = f.label :password, t("devise.passwords.edit.new_password"), class: "block text-gray-700 mb-2"
        - if @minimum_password_length
          %em.text-xs.text-gray-500.mb-1
            (#{@minimum_password_length} characters minimum)
        = f.password_field :password, autofocus: true, autocomplete: "new-password", class: "border rounded w-full px-3 py-2"
        - if resource.errors[:password].any?
          %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:password).first
      .mb-4
        = f.label :password_confirmation, t("devise.passwords.edit.confirm_new_password"), class: "block text-gray-700 mb-2"
        = f.password_field :password_confirmation, autocomplete: "new-password", class: "border rounded w-full px-3 py-2"
        - if resource.errors[:password_confirmation].any?
          %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:password_confirmation).first
      .mb-6
        = f.submit t("devise.passwords.edit.change_my_password"), class: "bg-brand hover:bg-brand-light text-white font-bold py-2 px-4 rounded w-full"
