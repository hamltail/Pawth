%div.flex.items-center.justify-center.min-h-screen.bg-gray-50
  %div.bg-white.shadow-md.rounded-lg.px-8.py-8.max-w-sm.w-full
    %h2.text-2xl.font-bold.mb-6.text-center Change your password
    = form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f|
      = render "devise/shared/error_messages", resource: resource
      = f.hidden_field :reset_password_token
      .mb-6
        = f.label :password, "New password", class: "block text-gray-700 mb-2"
        - if @minimum_password_length
          %em.text-xs.text-gray-500.mb-1
            (#{@minimum_password_length} characters minimum)
        = f.password_field :password, autofocus: true, autocomplete: "new-password", class: "border rounded w-full px-3 py-2"
      .mb-6
        = f.label :password_confirmation, "Confirm new password", class: "block text-gray-700 mb-2"
        = f.password_field :password_confirmation, autocomplete: "new-password", class: "border rounded w-full px-3 py-2"
      .mb-6
        = f.submit "Change my password", class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded w-full"
    .flex.justify-between.text-sm
      = link_to "Sign in", new_session_path(resource_name), class: "text-blue-500 hover:underline"
      = link_to "Sign up", new_registration_path(resource_name), class: "text-blue-500 hover:underline"
