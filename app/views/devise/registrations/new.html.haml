%div.flex.items-center.justify-center.min-h-screen.bg-gray-50
  %div.bg-white.shadow-md.rounded-lg.px-8.py-8.max-w-sm.w-full
    %h2.text-2xl.font-bold.mb-6.text-center
      = t("devise.shared.sign_up")
    - if resource.errors.any?
      %div.bg-red-100.border.border-red-400.text-red-700.px-4.py-4.rounded.mb-6
        %p.font-bold= "#{resource.errors.count}件のエラーがあります。"
        %ul.ml-4.list-disc
          - priority = [:username, :email, :password, :password_confirmation]
          - sorted_errors = resource.errors.messages.sort_by { |k, _| priority.index(k) }
          - sorted_errors.each do |attribute, messages|
            - messages.each do |msg|
              %li= resource.class.human_attribute_name(attribute) + msg
    = form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f|
      .mb-4
        = f.label :username, class: "block text-gray-700 mb-2"
        = f.text_field :username, autofocus: true, autocomplete: "username", class: "border rounded w-full px-3 py-2"
        - if resource.errors[:username].any?
          %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:username).first
      .mb-4
        = f.label :email, class: "block text-gray-700 mb-2"
        = f.email_field :email, autocomplete: "email", class: "border rounded w-full px-3 py-2"
        - if resource.errors[:email].any?
          %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:email).first
      .mb-4
        = f.label :password, class: "block text-gray-700"
        - if @minimum_password_length
          %em.text-xs.text-gray-500.mb-1
            (#{@minimum_password_length} characters minimum)
        = f.password_field :password, autocomplete: "new-password", class: "border rounded w-full px-3 py-2"
        - if resource.errors[:password].any?
          %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:password).first
      .mb-4
        = f.label :password_confirmation, class: "block text-gray-700 mb-2"
        = f.password_field :password_confirmation, autocomplete: "new-password", class: "border rounded w-full px-3 py-2"
        - if resource.errors[:password_confirmation].any?
          %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:password_confirmation).first
      .mb-6
        = f.submit t("devise.shared.sign_up"), class: "bg-teal-400 hover:bg-teal-500 text-white font-bold py-2 px-4 rounded w-full"
    .flex.justify-between.text-sm
      = link_to t("devise.shared.sign_in"), new_session_path(resource_name), class: "text-blue-500 hover:underline"
      = link_to t("devise.shared.forgot_your_password"), new_password_path(resource_name), class: "text-blue-500 hover:underline"
