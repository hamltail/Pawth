%div.bg-white.shadow-md.rounded-lg.px-8.py-8
  %h2.text-2xl.font-bold.text-brand-dark.neon-yellow-soft.mb-8.text-center= t("users.edit.title")
  = form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, multipart: true, data: { turbo: "false" } }) do |f|
    - if resource.errors.any?
      %div.bg-red-100.border.border-red-400.text-red-700.px-4.py-4.rounded.mb-6
        %p.font-bold= "#{resource.errors.count}件のエラーがあります。"
        %ul.ml-4.list-disc
          - priority = [:email, :password, :password_confirmation, :current_password]
          - sorted_errors = resource.errors.messages.sort_by { |k, _| priority.index(k) }
          - sorted_errors.each do |attribute, messages|
            - messages.each do |msg|
              %li= resource.class.human_attribute_name(attribute) + msg
    .mb-4
      = f.label :email, class: "block text-gray-700 mb-2"
      = f.email_field :email, autocomplete: "email", class: "border rounded w-full px-3 py-2"
      - if resource.errors[:email].any?
        %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:email).first
    .mb-4
      = f.label :password, class: "block text-gray-700"
      %span.text-xs.text-gray-500.ml-1= t("devise.registrations.edit.password_hint_nochange")
      - if @minimum_password_length
        %em.text-xs.text-gray-500.ml-2= t("devise.shared.password_min_length", length: @minimum_password_length)
      = f.password_field :password, autocomplete: "new-password", class: "border rounded w-full px-3 py-2"
      - if resource.errors[:password].any?
        %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:password).first
    .mb-4
      = f.label :password_confirmation, class: "block text-gray-700 mb-2"
      = f.password_field :password_confirmation, autocomplete: "new-password", class: "border rounded w-full px-3 py-2"
      - if resource.errors[:password_confirmation].any?
        %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:password_confirmation).first
    .mb-4
      = f.label :current_password, class: "block text-gray-700"
      %span.text-xs.text-gray-500.ml-1= t("devise.registrations.edit.current_password_hint")
      = f.password_field :current_password, autocomplete: "current-password", class: "border rounded w-full px-3 py-2"
      - if resource.errors[:current_password].any?
        %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:current_password).first
    .mb-6.text-center
      = f.submit t("users.edit.update"), class: "bg-brand hover:bg-brand-light text-white font-bold py-2 px-8 rounded"
%div.bg-white.shadow-md.rounded-lg.px-8.py-8.mt-24
  %section
    %h2.text-red-600.font-bold.mb-2 危険な操作
    %p.text-sm.text-gray-500.mb-4 この操作は取り消せません。関連データも削除されます。
    = form_with scope: resource_name, url: registration_path(resource_name),
                method: :delete, local: true, data: { turbo: "false" } do |f|
      .mb-2
        = f.label :current_password, '現在のパスワード', class: "block text-gray-700 mb-2"
        = f.password_field :current_password, required: true, autocomplete: "current-password", class: "border rounded w-full px-3 py-2"
      = f.submit 'アカウントを完全に削除する', class: "bg-red-600 hover:bg-red-500 text-white font-bold py-2 px-6 rounded",
        data: { confirm: '本当に削除しますか？この操作は取り消せません。' }
