%div.bg-white.shadow-md.rounded-lg.px-8.py-8
  %h2.text-2xl.font-bold.mb-6.text-center= t("users.edit.title")
  = form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, multipart: true }) do |f|
    - if resource.errors.any?
      %div.bg-red-100.border.border-red-400.text-red-700.px-4.py-4.rounded.mb-6
        %p.font-bold= "#{resource.errors.count}件のエラーがあります"
        %ul.ml-4.list-disc
          - priority = [:avatar, :display_name, :profile_message, :email, :password, :password_confirmation, :current_password]
          - sorted_errors = resource.errors.messages.sort_by { |k, _| priority.index(k) }
          - sorted_errors.each do |attribute, messages|
            - messages.each do |msg|
              %li= resource.class.human_attribute_name(attribute) + msg
    .mb-4
      = f.label :public_profile, "公開設定", class: "block text-gray-700 mb-2"
      %div.flex.items-center.gap-2
        = f.check_box :public_profile, { class: "sr-only", id: "toggle-public-profile" }
        %label{ for: "toggle-public-profile", class: "relative" }
          %span#toggle-bar.block.w-16.h-8.bg-gray-300.rounded-full
          %span.toggle-dot.absolute.left-0.top-0.w-8.h-8.bg-white.rounded-full.shadow-md
        %span#public-profile-label= resource.public_profile? ? "公開" : "非公開"
    .mb-4
      = f.label :avatar, t("activerecord.attributes.user.avatar"), class: "block text-gray-700 mb-2"
      - if resource.avatar.attached? && resource.avatar.blob&.persisted?
        %img#avatar-preview.mt-2.mb-2.rounded.w-24.h-24.object-cover{ src: url_for(resource.avatar), alt: "preview" }
      = f.file_field :avatar, id: "avatar-input", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
      - if resource.errors[:avatar].any?
        %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:avatar).first
    .mb-4
      = f.label :display_name, t("activerecord.attributes.user.display_name"), class: "block text-gray-700 mb-2"
      = f.text_field :display_name, class: "border rounded w-full px-3 py-2"
      - if resource.errors[:display_name].any?
        %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:display_name).first
    .mb-4
      = f.label :profile_message, t("activerecord.attributes.user.profile_message"), class: "block text-gray-700 mb-2"
      = f.text_area :profile_message, rows: 3, class: "border rounded w-full px-3 py-2"
      - if resource.errors[:profile_message].any?
        %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:profile_message).first
    .mb-4
      = f.label :email, class: "block text-gray-700 mb-2"
      = f.email_field :email, autofocus: true, autocomplete: "email", class: "border rounded w-full px-3 py-2"
      - if resource.errors[:email].any?
        %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:email).first
    -# - if devise_mapping.confirmable? && resource.pending_reconfirmation?
    -#   %div.text-sm.text-yellow-700.mb-2
    -#     新しいメールアドレス（#{resource.unconfirmed_email}）の確認をお待ちください
    .mb-4
      = f.label :password, class: "block text-gray-700"
      %span.text-xs.text-gray-500.ml-1 (変更しない場合は空欄のままにしてください)
      - if @minimum_password_length
        %em.text-xs.text-gray-500.ml-2 (#{@minimum_password_length} 文字以上で入力してください)
      = f.password_field :password, autocomplete: "new-password", class: "border rounded w-full px-3 py-2"
      - if resource.errors[:password].any?
        %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:password).first
    .mb-4
      = f.label :password_confirmation, class: "block text-gray-700 mb-2"
      = f.password_field :password_confirmation, autocomplete: "new-password", class: "border rounded w-full px-3 py-2"
      - if resource.errors[:password_confirmation].any?
        %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:password_confirmation).first
    .mb-4
      = f.label :current_password, class: "block text-gray-700"
      %span.text-xs.text-gray-500.ml-1 (変更を確定するには現在のパスワードが必要です)
      = f.password_field :current_password, autocomplete: "current-password", class: "border rounded w-full px-3 py-2"
      - if resource.errors[:current_password].any?
        %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:current_password).first
    .mb-6.text-center
      = f.submit t("users.edit.update"), class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-8 rounded"
  .mt-4
    = link_to t("users.edit.back"), :back, class: "text-blue-500 hover:underline"
