%div.flex.items-center.justify-center.min-h-screen.bg-gray-50
  %div.bg-white.shadow-md.rounded-lg.px-8.py-8.max-w-sm.w-full
    %h2.text-2xl.font-bold.mb-6.text-center
      = t("devise.shared.sign_in")
    - if flash.alert
      %div.bg-red-100.border.border-red-400.text-red-700.px-4.py-4.rounded.mb-4
        %p= flash.alert
    - if flash.notice
      %div.bg-green-100.border.border-green-400.text-green-700.px-4.py-4.rounded.mb-4
        %p= flash.notice
    = form_for(resource, as: resource_name, url: session_path(resource_name)) do |f|
      .mb-4
        = f.label :login, t("devise.sessions.username_or_email"), class: "block text-gray-700 mb-2"
        = f.text_field :login, autofocus: true, autocomplete: "username", class: "border rounded w-full px-3 py-2"
      .mb-4
        = f.label :password, t("attributes.password"), class: "block text-gray-700 mb-2"
        = f.password_field :password, autocomplete: "current-password", class: "border rounded w-full px-3 py-2"
      - if devise_mapping.rememberable?
        .mb-4.flex.items-center
          = f.check_box :remember_me, class: "mr-2"
          = f.label :remember_me, t("devise.sessions.remember_me"), class: "text-gray-700"
      .mb-6
        = f.submit t("devise.shared.sign_in"), class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded w-full"
    .flex.justify-between.text-sm
      = link_to t("devise.shared.sign_up"), new_registration_path(resource_name), class: "text-blue-500 hover:underline"
      = link_to t("devise.shared.forgot_your_password"), new_password_path(resource_name), class: "text-blue-500 hover:underline"
