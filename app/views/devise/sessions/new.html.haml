%div.flex.items-center.justify-center.min-h-screen.bg-gray-50
  %div.bg-white.shadow-md.rounded-lg.px-8.py-8.max-w-sm.w-full
    %h2.text-2xl.font-bold.mb-6.text-center Sign in
    = form_for(resource, as: resource_name, url: session_path(resource_name)) do |f|
      .mb-4
        = f.label :login, "Username or email address", class: "block text-gray-700 mb-2"
        = f.text_field :login, autofocus: true, autocomplete: "username", class: "border rounded w-full px-3 py-2"
      .mb-4
        = f.label :password, class: "block text-gray-700 mb-2"
        = f.password_field :password, autocomplete: "current-password", class: "border rounded w-full px-3 py-2"
      - if devise_mapping.rememberable?
        .mb-4.flex.items-center
          = f.check_box :remember_me, class: "mr-2"
          = f.label :remember_me, class: "text-gray-700"
      .mb-6
        = f.submit "Sign in", class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded w-full"
    .flex.justify-between.text-sm
      = link_to "Sign up", new_registration_path(resource_name), class: "text-blue-500 hover:underline"
      = link_to "Forgot your password?", new_password_path(resource_name), class: "text-blue-500 hover:underline"
