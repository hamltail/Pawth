%div.flex.items-center.justify-center.min-h-screen.bg-gray-50
  %div.bg-white.shadow-md.rounded-lg.px-8.py-8.max-w-sm.w-full
    %h2.text-2xl.font-bold.mb-6.text-center.text-brand-dark.neon-yellow-soft
      = t('devise.confirmations.resend_title')

    - if resource.errors.any?
      %div.bg-red-100.border.border-red-400.text-red-700.px-4.py-4.rounded.mb-6
        %p.font-bold= t('errors.messages.not_saved.other', resource: resource.class.model_name.human, count: resource.errors.count)
        %ul.ml-4.list-disc
          - resource.errors.full_messages.each do |msg|
            %li= msg

    = form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post }) do |f|
      .mb-4
        = f.label :email, class: 'block text-gray-700 mb-2'
        = f.email_field :email,
          autofocus: true,
          autocomplete: 'email',
          value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
          class: 'border rounded w-full px-3 py-2'
        - if resource.errors[:email].any?
          %p.text-red-500.text-sm.mt-1= resource.errors.full_messages_for(:email).first

      .mb-6
        = f.submit t('devise.confirmations.resend_button'), class: 'bg-brand hover:bg-brand-light text-white font-bold py-2 px-4 rounded w-full'
