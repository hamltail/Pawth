.mb-8#calendar{
  data: {
    controller: 'calendar',
    action: 'mouseover->calendar#handleMouseover click->calendar#handleClick'
  }
}
  - meta = calendar_meta(calendar_days)

  .flex.items-center.justify-center.mb-8
    = link_to activity_path(username: user.username, year: prev_month.year, month: prev_month.month),
              class: 'mx-2',
              aria: { label: t('activities.calendar.prev_month') } do
      = render 'shared/icon_arrow', direction: 'left', klass: 'text-gray-400 hover:text-gray-700'

    %h2.text-lg.font-bold.mx-4.flex-1.text-center{ aria: { live: 'polite' } }= meta[:month_label]

    = link_to activity_path(username: user.username, year: next_month.year, month: next_month.month),
              class: 'mx-2',
              aria: { label: t('activities.calendar.next_month') } do
      = render 'shared/icon_arrow', direction: 'right', klass: 'text-gray-400 hover:text-gray-700'

  .grid.grid-cols-7.gap-2.justify-center.mb-8
    - meta[:weekdays].each do |wd|
      .text-xs.font-bold.text-center= wd

  .grid.grid-cols-7.gap-2.justify-center.h-120
    - meta[:leading_empty].times do
      %div

    - calendar_days.each do |date|
      - post = first_post_on(date, daily_posts_by_date)
      %div{ class: day_cell_classes(date) }
        %span.text-xs= date.day
        = paw_icon_for(date, post)
        - if calendar_today?(date)
          = today_badge

    - meta[:trailing_empty].times do
      %div
