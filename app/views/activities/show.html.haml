- page_title = "#{@user.username}さんの日記"
%div.bg-white.shadow-md.rounded-lg.px-8.py-8.relative
  %h1.text-2xl.font-bold.text-gray-700.mb-8.text-center= page_title
  %div.flex.flex-col.items-center
    = avatar_for(@user, size: 80, css: "mb-4")
  - if user_signed_in? && current_user == @user
    %div.mb-8.text-center
      %strong.text-yellow-600.text-lg ようこそ、#{current_user.username}さん！
    %div.absolute.top-8.right-8
      = link_to "＋", new_daily_post_path, data: { turbo_frame: "modal",
          controller: "new-post-button",
          action: "click->new-post-button#handle",
          new_post_button_posted_today_value: current_user.posted_today?,
          new_post_button_message_value: "今日はすでに日記をかいています" },
        class: "inline-block bg-teal-400 hover:bg-teal-500 text-white font-bold py-2 px-4 rounded-full text-xl"
      = turbo_frame_tag "modal"
  = turbo_frame_tag "calendar", data: { turbo_cache: "false" } do
    = render "calendar",
      user: @user,
      calendar_days: @calendar_days,
      daily_posts_by_date: @daily_posts_by_date,
      prev_month: @prev_month,
      next_month: @next_month,
      month_label: @month_label
  - can_view_posts = @user.public_posts? || (user_signed_in? && current_user == @user)
  = turbo_frame_tag "latest_post" do
    - if can_view_posts
      = render "activities/latest_post", post: @latest_daily_post
    - else
      %div.flex.flex-col.items-center.justify-center.h-32.bg-gray-50.rounded-lg.shadow-inner
        %span.text-gray-400 日記は非公開です
  %div.text-xs.text-gray-400.text-center.mt-8 Pawth © 2025
