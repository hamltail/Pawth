%aside.bg-white.shadow-md.w-64.h-screen.px-6.py-6.flex.flex-col.justify-between.fixed.z-40.transform.transition-transform.duration-200.-translate-x-full.md:translate-x-0.md:flex{ id: "sidebar" }
  %div
    %div.text-lg.font-bold.text-blue-600.mb-8
      = link_to "Pawth", root_path, class: "hover:underline"
    %nav.flex.flex-col.space-y-6
      = link_to "Home", root_path, class: "text-gray-700 hover:text-blue-500 font-medium"
      = link_to "Posts", daily_posts_path, class: "text-gray-700 hover:text-blue-500 font-medium"
      = link_to "Edit Profile", edit_user_registration_path, class: "text-gray-700 hover:text-blue-500 font-medium"
      = link_to "Sign out", destroy_user_session_path,
          data: { turbo_method: :delete, turbo_confirm: "本当にログアウトしますか？" },
          class: "sidebar-no-close text-red-500 hover:underline font-medium"
  %div.text-xs.text-gray-400.mt-8 Pawth © 2025
