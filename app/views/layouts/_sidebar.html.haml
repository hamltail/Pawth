%aside.bg-white.shadow-md.w-64.h-screen.px-6.py-6.flex.flex-col.justify-between.fixed.z-60.transform.transition-transform.duration-200.-translate-x-full.md:translate-x-0.md:flex{ 
  id: 'sidebar',
  data: { menu_target: 'sidebar' }
}
  %div
    .text-lg.font-bold.text-teal-700.mb-8
      = link_to 'Pawth', root_path, class: 'hover:underline neon-pink'
    %nav.flex.flex-col.space-y-6
      = link_to 'カレンダー', root_path, class: 'text-gray-700 hover:text-teal-400 font-medium'
      = link_to '日記一覧', daily_posts_path, class: 'text-gray-700 hover:text-teal-400 font-medium'

      %div{ data: { controller: 'collapsible', open: 'false' } }
        %button.w-full.flex.items-center.justify-between.text-gray-700.font-medium.hover:text-teal-400{
          type: 'button',
          data: { action: 'click->collapsible#toggle' },
          aria: { expanded: 'false', controls: 'settings-submenu' }
        }
          設定
          %span.transition-transform.duration-200{ data: { collapsible_target: 'icon' } } ▶
        %ul.mt-2.pl-4.space-y-2.hidden#settings-submenu{ data: { collapsible_target: 'panel' } }
          %li= link_to 'プロフィール設定', edit_profile_path, class: 'text-gray-700 hover:text-teal-400 font-medium'
          %li= link_to 'アカウント設定', edit_user_registration_path, class: 'text-gray-700 hover:text-teal-400 font-medium'

      = link_to 'ログアウト', destroy_user_session_path,
          data: { turbo_method: :delete, turbo_confirm: '本当にログアウトしますか？' },
          class: 'sidebar-no-close text-red-600 hover:underline font-medium'
  .text-xs.text-gray-500.mt-8 Pawth © 2025
