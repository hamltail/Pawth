!!!
%html{ lang: (I18n.locale || I18n.default_locale).to_s }
  %head
    %meta{:content => "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %title= content_for(:title) || "Pawth"
    %meta{:content => "width=device-width,initial-scale=1", :name => "viewport"}/
    %meta{:content => "yes", :name => "apple-mobile-web-app-capable"}/
    %meta{:content => "yes", :name => "mobile-web-app-capable"}/
    = csrf_meta_tags
    = csp_meta_tag
    = yield :head
    %link{ rel: "icon", type: "image/png", href: asset_path("pawth.png") }/
    %link{ href: asset_path("pawth.png"), rel: "apple-touch-icon" }/
    = stylesheet_link_tag :app, "data-turbo-track": "reload"
    = javascript_importmap_tags
  %body
    %div.flex.min-h-screen.bg-gray-50{ data: { controller: 'menu' } } 
      - if user_signed_in?
        %button.md:hidden.fixed.top-8.left-8.z-50.bg-white.p-2.rounded-lg.shadow-lg{ 
          id: 'menu-button',
          data: { action: 'click->menu#toggle', menu_target: 'button' } }
          %svg.w-6.h-6{:fill=>"none", :stroke=>"currentColor", :viewBox=>"0 0 24 24"}
            %path{ d: "M4 6h16M4 12h16M4 18h16", stroke: "#1f2937", "stroke-width"=>"2", "stroke-linecap"=>"round", "stroke-linejoin"=>"round" }
        = render 'layouts/sidebar'
      - else
        %header.fixed.top-8.left-8.z-40
          = link_to "Pawth",
                    new_user_session_path,
                    class: "text-brand font-extrabold text-xl hover:underline",
                    aria: { label: "Pawth ログインへ" }
      - main_class = user_signed_in? ? "ml-0 md:ml-64 flex-1" : "flex-1"
      %main{ class: main_class }
        %div.max-w-screen-md.mx-auto
          = yield
