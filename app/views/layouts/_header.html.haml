- if user_signed_in?
  %header.bg-white.shadow-md.px-6.py-3.flex.items-center.justify-between
    %div.text-lg.font-bold.text-blue-600
      = link_to "Pawth", root_path, class: "hover:underline"
    %nav.flex.space-x-6
      = link_to "Home", root_path, class: "text-gray-700 hover:text-blue-500 font-medium"
      = link_to "Posts", daily_posts_path, class: "text-gray-700 hover:text-blue-500 font-medium"
      = button_to "Sign out", destroy_user_session_path, method: :delete, class: "text-red-500 hover:underline font-medium bg-transparent border-none p-0"
