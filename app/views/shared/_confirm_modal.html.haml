%dialog#confirm-modal{ data: { controller: 'modal-confirm', modal_confirm_target: 'dialog' },
  class: 'p-0 border-0 bg-transparent' }
  %div{ class: 'p-8 w-[min(92vw,420px)] bg-white rounded-2xl shadow-xl' }
    %h3.text-lg.font-semibold.mb-4 確認
    %p.text-gray-700.mb-8{ data: { modal_confirm_target: 'message' } } 本当に削除しますか？
    .flex.justify-end.gap-4
      %button.px-4.py-2.rounded-xl.ring-1.ring-gray-300{ type: 'button', data: { action: 'modal-confirm#cancel' } } キャンセル
      %button.px-4.py-2.rounded-xl.bg-red-600.text-white{ type: 'button', data: { action: 'modal-confirm#ok' } } 実行する
